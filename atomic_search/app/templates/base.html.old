<!DOCTYPE html>
<html lang="en" data-theme="{{ theme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ config.app_name }} - A privacy-focused search engine">
    <meta name="robots" content="noindex, nofollow">
    <title>{% block title %}{{ config.app_name }}{% endblock %}</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/main.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/theme-' + theme + '.css') }}" id="theme-stylesheet">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="{{ url_for('static', filename='img/favicon.svg') }}">
    
    {% block extra_head %}{% endblock %}
</head>
<body class="{% if compact_mode %}compact{% endif %}">
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="{{ url_for('main.index') }}" class="nav-logo">
                <svg class="logo-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                    <circle cx="12" cy="12" r="4" fill="currentColor"/>
                    <path d="M12 2v4M12 18v4M2 12h4M18 12h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="logo-text">{{ config.app_name }}</span>
            </a>
            
            <div class="nav-search">
                <form action="{{ url_for('main.search') }}" method="GET" class="search-form">
                    <div class="search-input-wrapper">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="M21 21l-4.35-4.35"/>
                        </svg>
                        <input type="text" name="q" placeholder="Search the web privately..." 
                               value="{{ query }}" autocomplete="off" id="search-input"
                               class="search-input" autofocus>
                        <button type="button" class="voice-search-btn" title="Voice search">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                                <line x1="12" y1="19" x2="12" y2="23"/>
                                <line x1="8" y1="23" x2="16" y2="23"/>
                            </svg>
                        </button>
                    </div>
                    <button type="submit" class="search-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="M21 21l-4.35-4.35"/>
                        </svg>
                        <span>Search</span>
                    </button>
                </form>
            </div>
            
            <div class="nav-links">
                <a href="{{ url_for('main.settings') }}" class="nav-link" title="Settings">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                    </svg>
                </a>
                <button class="theme-toggle" title="Toggle theme" id="theme-toggle">
                    <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="5"/>
                        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                    </svg>
                    <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                </button>
                {% if config.bookmarks_enabled %}
                <a href="{{ url_for('main.bookmarks') }}" class="nav-link" title="Bookmarks">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                    </svg>
                </a>
                {% endif %}
                <a href="{{ url_for('admin.login') }}" class="nav-link admin-link" title="Admin">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </a>
            </div>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main class="main-content">
        {% block content %}{% endblock %}
    </main>
    
    <!-- AI Chat Sidebar -->
    {% if config.ai_enabled %}
    <aside class="ai-sidebar" id="ai-sidebar">
        <div class="ai-sidebar-header">
            <h3>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2a10 10 0 0 1 10 10c0 5.52-4.48 10-10 10S2 17.52 2 12c0-1.85.5-3.58 1.38-5.08"/>
                    <path d="M12 6v6l4 2"/>
                </svg>
                AI Assistant
            </h3>
            <button class="ai-sidebar-toggle" id="ai-sidebar-toggle">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
        </div>
        <div class="ai-chat-container">
            <div class="ai-messages" id="ai-messages">
                <div class="ai-message ai-message-bot">
                    <div class="ai-message-content">
                        Hello! I'm your AI assistant powered by {{ config.ai_provider }}. 
                        I can help summarize search results, answer questions, and more.
                    </div>
                </div>
            </div>
            <form class="ai-input-form" id="ai-input-form">
                <textarea id="ai-input" placeholder="Ask me anything..." rows="1"></textarea>
                <button type="submit" class="ai-send-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>
            </form>
        </div>
    </aside>
    {% endif %}
    
    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-links">
                <a href="{{ url_for('main.about') }}">About</a>
                <a href="{{ url_for('main.privacy') }}">Privacy</a>
                <a href="{{ url_for('main.terms') }}">Terms</a>
                <a href="https://github.com/atomic-search/atomic-search" target="_blank" rel="noopener">GitHub</a>
            </div>
            <div class="footer-text">
                <p>{{ config.app_name }} v{{ config.app_version }} - Privacy-first search</p>
                <p class="footer-privacy">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    No tracking. No ads. No cookies.
                </p>
            </div>
        </div>
    </footer>
    
    <!-- Scripts -->
    <script src="{{ url_for('static', filename='js/main.js') }}"></script>
    {% block scripts %}{% endblock %}
    
    <!-- Keyboard Shortcuts -->
    {% if config.keyboard_shortcuts_enabled %}
    <script>
        document.addEventListener('keydown', function(e) {
            // Focus search: /
            if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                e.preventDefault();
                document.getElementById('search-input')?.focus();
            }
            // Toggle theme: t
            if (e.key === 't' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                e.preventDefault();
                toggleTheme();
            }
            // Toggle AI sidebar: a
            if (e.key === 'a' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA' && document.getElementById('ai-sidebar')) {
                e.preventDefault();
                toggleAISidebar();
            }
            // Escape to close modals
            if (e.key === 'Escape') {
                closeAllModals();
            }
        });
    </script>
    {% endif %}
</body>
</html>
